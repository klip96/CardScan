# --- Виртуальное окружение ---
venv/
.venv/

# --- Python кэш ---
__pycache__/
*.pyc
*.pyo

# --- Локальная конфигурация и секреты (НЕ коммитить) ---
config.yaml
service_account.json

# --- Данные времени выполнения ---
data/photos/
data/users.json
data/sessions.json

# --- Сборка PyInstaller / инсталлятор ---
build/
dist/
*.spec.bak
_entry.py
Output/

# --- Android-приложение (Capacitor) ---
android-app/node_modules/
android-app/android/
android-app/android-sdk/
android-app/.gradle/
android-app/*.log

# --- Прочее ---
*.log
.DS_Store
